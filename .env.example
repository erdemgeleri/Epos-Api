MSSQL_SA_PASSWORD=PosDemo_Sql_2026_Strong!

# JWT — production’da mutlaka değiştirin (en az 32 karakter önerilir)
JWT_SECRET=PosDemoJwt_ChangeInProduction_Min32Chars_Required
JWT_ISSUER=PosDemo
JWT_AUDIENCE=PosDemo

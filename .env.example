# copy .env.example .env

# --- SQL (tercih: parçalı — connection string elle yazmaya gerek yok) ---
# Docker’da sqlserver konteynerı (bundled-db profili) veya aynı ağdaki host adı:
MSSQL_HOST=sqlserver
MSSQL_PORT=1433
MSSQL_DATABASE=PosDemoDb
MSSQL_USER=sa
# Yerleşik SQL kullanıyorsanız MSSQL_SA_PASSWORD ile aynı olmalı
MSSQL_PASSWORD=EposBundledSa_2026_kQ8mN2pR5vL9

# İsteğe bağlı: MSSQL_HOST kullanmıyorsanız tek satır (ConnectionStrings__DefaultConnection)
# ConnectionStrings__DefaultConnection=Server=...;Database=...;User Id=...;Password=...;TrustServerCertificate=True;MultipleActiveResultSets=true

API_HOST_PORT=8081

JWT_SECRET=EposJwt_DevOnly_7kN2mP9qR4vL8xW3bH6jF5sD1yT0cA_gU4oI7nM
JWT_ISSUER=PosDemo
JWT_AUDIENCE=PosDemo

